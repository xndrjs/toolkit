{
  "name": "@xndrjs/i18n",
  "version": "0.8.0",
  "description": "Compiler-first, type-safe ICU MessageFormat i18n with lazy delivery loading and external payload validation for content ingest.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xndrjs/toolkit.git",
    "directory": "packages/i18n"
  },
  "type": "module",
  "bin": {
    "xndrjs-i18n-codegen": "./bin/codegen.mjs",
    "xndrjs-i18n-setup": "./bin/setup.mjs",
    "xndrjs-i18n-audit": "./bin/audit.mjs"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "default": "./dist/validation/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js",
      "default": "./dist/codegen/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "pack": "pnpm run build && mkdir -p artifacts && npm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "^3.5.12",
    "intl-messageformat": "^11.2.9",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "tsx": ">=4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
