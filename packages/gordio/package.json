{
  "name": "@xndrjs/gordio",
  "version": "0.0.0",
  "description": "Architecture graph analysis and future React Flow tooling for xndrjs projects.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xndrjs/toolkit.git",
    "directory": "packages/gordio"
  },
  "type": "module",
  "bin": {
    "gordio": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "gordio": "tsx src/cli.ts",
    "pack": "pnpm run build && mkdir -p artifacts && npm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "jiti": "^2.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
