{
  "name": "@xndrjs/branded",
  "version": "0.3.0-alpha.1",
  "deprecated": "Use @xndrjs/domain (core) and @xndrjs/domain-zod (Zod). @xndrjs/branded is deprecated; further adapters are planned.",
  "description": "Zod-first branded types for domain modeling (deprecated; use @xndrjs/domain-zod).",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xndrjs/toolkit.git",
    "directory": "packages/branded"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "pack": "pnpm run build && mkdir -p artifacts && npm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
