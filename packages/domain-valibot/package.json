{
  "name": "@xndrjs/domain-valibot",
  "version": "0.2.0",
  "description": "Valibot adapter for @xndrjs/domain with function-first APIs: valibotToValidator and valibotFromKit, plus full domain re-export.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xndrjs/toolkit.git",
    "directory": "packages/domain-valibot"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "pack": "pnpm run build && mkdir -p artifacts && npm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "valibot": "^1.3.1"
  },
  "dependencies": {
    "@xndrjs/domain": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "valibot": "^1.3.1",
    "vitest": "^4.1.0"
  }
}
