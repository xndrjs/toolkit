{
  "name": "@xndrjs/data-layer",
  "version": "0.1.2-alpha.1",
  "description": "Data layer utilities: batch loaders, registry, mapping helpers.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xndrjs/toolkit.git",
    "directory": "packages/data-layer"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "pack": "pnpm run build && mkdir -p artifacts && npm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "dataloader": "^2.2.0"
  },
  "devDependencies": {
    "dataloader": "^2.2.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
