{
  "name": "@xndrjs/react-adapter",
  "version": "0.1.0",
  "description": "React hooks that implement orchestration ports.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xndrjs/toolkit.git",
    "directory": "packages/react-adapter"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "pack": "pnpm run build && mkdir -p artifacts && npm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "@xndrjs/orchestration": "workspace:^"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
