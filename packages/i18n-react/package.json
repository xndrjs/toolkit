{
  "name": "@xndrjs/i18n-react",
  "version": "0.8.0",
  "description": "React runtime primitives and codegen for @xndrjs/i18n client bindings.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xndrjs/toolkit.git",
    "directory": "packages/i18n-react"
  },
  "type": "module",
  "bin": {
    "xndrjs-i18n-react-codegen": "./bin/codegen.mjs"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "codegen": "tsx src/codegen/generate-react-bindings.ts",
    "pack": "pnpm run build && mkdir -p artifacts && npm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --config ../../vitest.config.ts --project i18n-react",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "peerDependencies": {
    "@xndrjs/i18n": "^0.8.0",
    "react": ">=19",
    "tsx": ">=4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@xndrjs/i18n": "workspace:^",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
