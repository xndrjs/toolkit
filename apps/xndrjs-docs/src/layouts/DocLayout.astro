---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar";
import TableOfContents from "../components/TableOfContents";
import { getSidebarData } from "../utils/sidebar";

interface Props {
  title: string;
  description?: string;
}

const { title, description = `Documentation for ${title}` } = Astro.props;
const sidebarData = await getSidebarData();
const currentPath = Astro.url.pathname;
---

<BaseLayout title={`${title} | xndrjs`} description={description}>
  <div class="doc-container">
    <Sidebar client:load items={sidebarData} currentPath={currentPath} />
    <div class="doc-content">
      <article class="doc-article">
        <slot />
      </article>
    </div>
    <div class="doc-toc">
      <TableOfContents client:load />
    </div>
  </div>
</BaseLayout>

<style>
  .doc-container {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr) 260px;
    gap: 0;
    min-height: calc(100vh - 60px);
    padding: 0;
    position: relative;
    width: 100%;
  }

  .doc-container::before {
    background: rgba(13, 17, 24, 0.72);
    border-right: 1px solid var(--xndr-border-subtle);
    bottom: 0;
    content: "";
    left: 0;
    position: absolute;
    top: 0;
    width: 260px;
    z-index: 0;
  }

  .doc-content {
    justify-self: center;
    max-width: 780px;
    padding: 3rem 0 4rem;
    width: 100%;
    z-index: 1;
  }

  .doc-toc {
    border-left: 1px solid var(--xndr-border-subtle);
    justify-self: stretch;
    min-height: 100%;
    padding: 3rem 0.75rem;
    width: 100%;
    z-index: 1;
  }

  .doc-article {
    color: var(--xndr-text-secondary);
    font-size: 1rem;
    line-height: 1.75;
  }

  .doc-article :global(p) {
    color: var(--xndr-text-secondary);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.1rem;
  }

  .doc-article :global(ul),
  .doc-article :global(ol) {
    margin: 1.15rem 0;
    padding-left: 1.35rem;
  }

  .doc-article :global(li) {
    margin: 0.45rem 0;
    padding-left: 0.15rem;
  }

  .doc-article :global(h1) {
    color: var(--xndr-text-primary);
    font-family: "Space Grotesk", sans-serif;
    font-size: 2.55rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.08;
    margin-bottom: 1.25rem;
  }

  .doc-article :global(h2) {
    border-bottom: 1px solid var(--xndr-border-subtle);
    color: var(--xndr-text-primary);
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 1rem;
    margin-top: 3rem;
    padding-bottom: 0.7rem;
  }

  .doc-article :global(h3) {
    color: var(--xndr-text-primary);
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.18rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 0.75rem;
    margin-top: 2rem;
  }

  .doc-article :global(a) {
    color: var(--xndr-cyan);
    text-decoration: none;
    text-underline-offset: 0.18em;
  }

  .doc-article :global(a:hover) {
    color: #8ae8ff;
    text-decoration: underline;
  }

  .doc-article :global(pre) {
    background: #0a0f17;
    border: 1px solid rgba(69, 214, 255, 0.16);
    border-radius: 10px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    margin: 1.35rem 0;
    overflow-x: auto;
    padding: 1.15rem 1.25rem;
  }

  .doc-article :global(.prism-code),
  .doc-article :global(.theme-code-block) {
    background: #0a0f17;
    border: 1px solid rgba(69, 214, 255, 0.16);
    border-radius: 10px;
    overflow: hidden;
  }

  .doc-article :global(code) {
    background: rgba(69, 214, 255, 0.08);
    border: 1px solid rgba(69, 214, 255, 0.16);
    border-radius: 6px;
    color: #d8f6ff;
    font-family: "JetBrains Mono", "Fira Code", "Consolas", "Monaco", monospace;
    font-size: 0.88em;
    padding: 0.14rem 0.38rem;
  }

  .doc-article :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
  }

  .doc-article :global(table) {
    border: 1px solid var(--xndr-border-subtle);
    border-collapse: collapse;
    border-radius: 10px;
    display: block;
    margin: 1.5rem 0;
    overflow-x: auto;
    width: 100%;
  }

  .doc-article :global(thead) {
    background: rgba(69, 214, 255, 0.08);
  }

  .doc-article :global(th),
  .doc-article :global(td) {
    border-bottom: 1px solid var(--xndr-border-subtle);
    padding: 0.78rem 0.9rem;
    text-align: left;
    vertical-align: top;
  }

  .doc-article :global(th) {
    color: var(--xndr-text-primary);
    font-weight: 700;
  }

  .doc-article :global(td) {
    color: var(--xndr-text-secondary);
  }

  .doc-article :global(blockquote) {
    background: rgba(69, 214, 255, 0.06);
    border-left: 3px solid var(--xndr-cyan);
    border-radius: 0 10px 10px 0;
    color: var(--xndr-text-primary);
    margin: 1.5rem 0;
    padding: 1rem 1.2rem;
  }

  @media (max-width: 1200px) {
    .doc-container {
      grid-template-columns: 260px minmax(0, 1fr);
    }

    .doc-toc {
      display: none;
    }
  }

  @media (max-width: 996px) {
    .doc-container {
      grid-template-columns: 1fr;
      padding: 0;
    }

    .doc-container::before {
      display: none;
    }

    .doc-content {
      padding: 2rem 1rem 3rem;
    }

    .doc-article :global(h1) {
      font-size: 2.1rem;
    }
  }
</style>

<style is:global>
  .sidebar {
    align-self: stretch;
    background: transparent;
    border-right: 0;
    height: calc(100vh - 60px);
    overflow-y: auto;
    padding: 1.5rem 0.75rem;
    position: sticky;
    top: 60px;
    width: 260px;
    z-index: 1;
  }

  .footer {
    margin-top: 0;
  }

  .sidebar-nav {
    padding: 0;
  }

  .sidebar-list,
  .sidebar-sublist {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-item {
    margin: 0.15rem 0;
  }

  .sidebar-category {
    align-items: center;
    background: none;
    border: 0;
    border-radius: 8px;
    color: var(--xndr-text-secondary);
    cursor: pointer;
    display: flex;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
    padding: 0.45rem 0.55rem;
    text-align: left;
    transition: background-color 0.2s ease, color 0.2s ease;
    width: 100%;
  }

  .sidebar-category:hover {
    background: rgba(69, 214, 255, 0.06);
    color: var(--xndr-text-primary);
  }

  .sidebar-category.active {
    color: var(--xndr-text-primary);
  }

  .sidebar-category-icon {
    color: var(--xndr-text-muted);
    display: inline-block;
    flex-shrink: 0;
    font-size: 0.72rem;
    text-align: center;
    transition: transform 0.2s ease;
    width: 0.75rem;
  }

  .sidebar-category.expanded .sidebar-category-icon {
    transform: rotate(90deg);
  }

  .sidebar-category-label {
    flex: 1;
  }

  .sidebar-link {
    border-radius: 8px;
    color: var(--xndr-text-muted);
    display: block;
    font-size: 0.98rem;
    line-height: 1.45;
    opacity: 1;
    padding: 0.42rem 0.55rem;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .sidebar-link:hover {
    background: rgba(69, 214, 255, 0.06);
    color: var(--xndr-text-primary);
    text-decoration: none;
  }

  .sidebar-link.active {
    background: rgba(69, 214, 255, 0.1);
    color: var(--xndr-text-primary);
    font-weight: 600;
    position: relative;
  }

  .sidebar-link.active::before {
    background: var(--xndr-cardinal);
    border-radius: 999px;
    bottom: 0.45rem;
    content: "";
    left: 0;
    position: absolute;
    top: 0.45rem;
    width: 2px;
  }

  .sidebar-sublist {
    margin: 0.25rem 0 0.5rem;
  }

  @media (max-width: 996px) {
    .sidebar {
      display: none;
    }

    .sidebar-mobile {
      display: block;
      left: -100%;
      position: fixed;
      top: 60px;
      transition: left 0.3s ease;
      width: 280px;
      z-index: 999;
    }

    .sidebar-mobile.open {
      left: 0;
    }
  }
</style>
