---
import { marked } from 'marked';

interface Props {
  content?: string; // Markdown content
}

const { content } = Astro.props;

// Process markdown content if provided
const contentHtml = content ? marked(content) : null;
---

{contentHtml && (
  <section class="see-also">
    <h2 class="see-also__title">See Also</h2>
    <div class="see-also__content" set:html={contentHtml} />
  </section>
)}

<style>
  .see-also {
    margin-top: 2rem;
    background: rgba(16, 23, 34, 0.72);
    border: 1px solid var(--xndr-border-subtle);
    border-radius: 8px;
    padding: 1.2rem 1.35rem;
  }

  .see-also__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--xndr-text-primary);
    margin-bottom: 1rem;
    font-family: "Space Grotesk", sans-serif;
  }

  .see-also__content {
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--xndr-text-secondary);
  }

  .see-also__content :global(ul),
  .see-also__content :global(ol) {
    margin: 1rem 0;
    padding-left: 2rem;
  }

  .see-also__content :global(li) {
    margin: 0.5rem 0;
  }

  .see-also__content :global(a) {
    color: var(--xndr-cyan);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .see-also__content :global(a:hover) {
    text-decoration: underline;
  }

  .see-also__content :global(p) {
    margin: 0.5rem 0;
  }

  .see-also__content :global(p:first-child) {
    margin-top: 0;
  }

  .see-also__content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
