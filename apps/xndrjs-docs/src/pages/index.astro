---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomepageHeader from '../components/HomepageHeader';
import FeatureCard from '../components/FeatureCard';
---

<BaseLayout
  title="xndrjs"
  description="Domain modeling toolkit with validator-agnostic adapters for Zod, AJV, and Valibot."
>
  <HomepageHeader client:load />
  <main class="main">
    <section class="featuresSection">
      <div class="featuresHeader">
        <h2 class="featuresTitle">Why xndrjs?</h2>
        <p class="featuresSubtitle">
          One domain contract, multiple validation engines
        </p>
      </div>
      <div class="featuresGrid">
        <FeatureCard
          client:load
          title="Validator Agnostic"
          description="Keep the same domain API while choosing Zod, AJV, or Valibot"
        />
        <FeatureCard
          client:load
          title="Domain-First"
          description="Model primitives, entities, and proofs with explicit runtime boundaries"
        />
        <FeatureCard
          client:load
          title="Adapter Interop"
          description="Convert schemas to domain validators and reuse kits across adapter layers"
        />
        <FeatureCard
          client:load
          title="Consistent Errors"
          description="Standardized validation failures across all engines and workflows"
        />
        <FeatureCard
          client:load
          title="Composable Utilities"
          description="Build validators with compose helpers and typed pipelines with pipe"
        />
        <FeatureCard
          client:load
          title="Benchmark Ready"
          description="Compare engines on shared scenarios with reproducible benchmark runs"
        />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .main {
    padding: 0;
  }

  .featuresSection {
    padding: 3rem 0;
    background: linear-gradient(135deg, rgba(107, 31, 46, 0.05) 0%, rgba(107, 31, 46, 0.02) 50%, rgba(0, 217, 255, 0.05) 100%);
    border-radius: 24px;
    margin: 3rem 0;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .featuresHeader {
    padding: 1rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .featuresTitle {
    font-size: 3rem;
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--xndr-primary-text);
    font-family: 'Lexend Exa', sans-serif;
    border-bottom: none;
    padding-bottom: 0;
  }

  .featuresSubtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  .featuresGrid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media screen and (max-width: 768px) {
    .featuresSection {
      background: transparent !important;
      border-radius: 0;
      margin: 1.5rem 0;
      padding: 1.5rem 0;
    }

    .featuresGrid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 0 1rem;
    }
  }
</style>

