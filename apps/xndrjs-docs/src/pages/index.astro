---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomepageHeader from '../components/HomepageHeader';
import FeatureCard from '../components/FeatureCard';
---

<BaseLayout
  title="xndrjs"
  description="Typed trust boundaries for plain immutable data, with validator-agnostic adapters for Zod, AJV, and Valibot."
>
  <HomepageHeader client:load />
  <main class="main">
    <section class="featuresSection">
      <div class="featuresHeader">
        <h2 class="featuresTitle">Why xndrjs?</h2>
        <p class="featuresSubtitle">
          One mental model, multiple validation engines
        </p>
      </div>
      <div class="featuresGrid">
        <FeatureCard
          client:load
          title="Trust Boundaries"
          description="Turn unknown input into named domain values through explicit create and assert steps"
        />
        <FeatureCard
          client:load
          title="Plain Immutable Data"
          description="Keep instances data-only and put behavior in capability methods on domain kits"
        />
        <FeatureCard
          client:load
          title="Adapter Interop"
          description="Use Zod, AJV, or Valibot as boundary validators without changing your domain model"
        />
        <FeatureCard
          client:load
          title="Consistent Errors"
          description="Standardized validation failures across all engines and workflows"
        />
        <FeatureCard
          client:load
          title="Composable Utilities"
          description="Build validators with compose helpers and typed pipelines with pipe"
        />
        <FeatureCard
          client:load
          title="Internal Benchmarks"
          description="Compare validation engines on shared workspace scenarios with reproducible runs"
        />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .main {
    padding: 0;
  }

  .featuresSection {
    padding: 4rem 0;
    background: rgba(8, 10, 15, 0.66);
    border-top: 1px solid var(--xndr-border-subtle);
    margin: 0;
    max-width: none;
    margin-left: auto;
    margin-right: auto;
  }

  .featuresHeader {
    padding: 1rem;
    text-align: center;
    margin-bottom: 2.25rem;
  }

  .featuresTitle {
    color: var(--xndr-text-primary);
    font-family: "Space Grotesk", sans-serif;
    font-size: 2.15rem;
    line-height: 1.15;
    margin-top: 0;
    margin-bottom: 1rem;
    border-bottom: none;
    padding-bottom: 0;
  }

  .featuresSubtitle {
    font-size: 1rem;
    color: var(--xndr-text-secondary);
    margin: 0;
  }

  .featuresGrid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media screen and (max-width: 768px) {
    .featuresSection {
      border-radius: 0;
      padding: 2.5rem 0;
    }

    .featuresGrid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 0 1rem;
    }
  }
</style>
