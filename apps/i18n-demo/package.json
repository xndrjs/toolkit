{
  "name": "@xndrjs/i18n-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "i18n:codegen:multi": "xndrjs-i18n-codegen --config multi/i18n/i18n.codegen.json",
    "i18n:codegen:areas": "xndrjs-i18n-codegen --config areas/i18n/i18n.codegen.json",
    "i18n:write-config:programmatic": "tsx programmatic/i18n/write-config.ts",
    "i18n:codegen:programmatic": "pnpm run i18n:write-config:programmatic && xndrjs-i18n-codegen --config programmatic/i18n/i18n.codegen.json",
    "i18n:react-codegen:multi": "xndrjs-i18n-react-codegen --config multi/i18n/i18n.codegen.json",
    "i18n:react-codegen:areas": "xndrjs-i18n-react-codegen --config areas/i18n/i18n.codegen.json",
    "i18n:react-codegen:programmatic": "xndrjs-i18n-react-codegen --config programmatic/i18n/i18n.codegen.json",
    "i18n:codegen": "pnpm run i18n:codegen:multi && pnpm run i18n:codegen:areas && pnpm run i18n:codegen:programmatic",
    "i18n:react-codegen": "pnpm run i18n:react-codegen:multi && pnpm run i18n:react-codegen:areas && pnpm run i18n:react-codegen:programmatic",
    "predev": "pnpm run i18n:codegen && pnpm run i18n:react-codegen",
    "prebuild": "pnpm run i18n:codegen && pnpm run i18n:react-codegen",
    "i18n:audit:multi": "xndrjs-i18n-audit --config multi/i18n/i18n.codegen.json",
    "i18n:audit:areas": "xndrjs-i18n-audit --config areas/i18n/i18n.codegen.json",
    "i18n:audit": "pnpm run i18n:audit:multi && pnpm run i18n:audit:areas",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xndrjs/i18n": "workspace:^",
    "@xndrjs/i18n-react": "workspace:^",
    "next": "^16.2.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
