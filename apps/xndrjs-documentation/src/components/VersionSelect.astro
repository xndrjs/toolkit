---
import Select from "@astrojs/starlight/components/Select.astro";
import { Icon } from "@astrojs/starlight/components";
import { docVersions } from "../starlight-versions";

const pathname = Astro.url.pathname;
const singleVersion = docVersions.length <= 1;

const knownPrefixes: string[] = docVersions.map((v) => v.slugPrefix);

function rewritePath(path: string, newPrefix: (typeof docVersions)[number]["slugPrefix"]): string {
  const normalized = path.replace(/\/$/, "") || "/";
  const parts = normalized.split("/").filter(Boolean);
  let rest: string[] = [];
  const head = parts[0];
  if (head && knownPrefixes.includes(head)) {
    rest = parts.slice(1);
  }
  const tail = rest.length ? `${rest.join("/")}/` : "";
  return `/${newPrefix}/${tail}`;
}

const options = docVersions.map((v) => {
  const atRoot = pathname === "/" || pathname.replace(/\/$/, "") === "";
  const parts = pathname.split("/").filter(Boolean);
  const selected =
    parts[0] === v.slugPrefix || (atRoot && v.slugPrefix === docVersions[0].slugPrefix);

  return {
    label: v.label,
    value: rewritePath(pathname, v.slugPrefix),
    selected,
  };
});

const selectWidth = "9.5em";
---

{
  singleVersion ? (
    <label
      class="doc-version-select doc-version-select--disabled"
      style={`--sl-select-width: ${selectWidth}`}
      title="Only one documentation line is published right now."
    >
      <span class="sr-only">Documentation version</span>
      <Icon name="document" class="icon label-icon" />
      <select autocomplete="off" disabled>
        {options.map(({ value, selected, label }) => (
          <option value={value} selected={selected} set:html={label} />
        ))}
      </select>
      <Icon name="down-caret" class="icon caret" />
    </label>
  ) : (
    <starlight-version-select>
      <Select
        icon="document"
        label="Documentation version"
        width={selectWidth}
        options={options}
      />
    </starlight-version-select>
  )
}

{
  !singleVersion && (
    <script>
      class StarlightVersionSelect extends HTMLElement {
        constructor() {
          super();
          const select = this.querySelector("select");
          if (!select) return;
          select.addEventListener("change", (e) => {
            if (e.currentTarget instanceof HTMLSelectElement) {
              window.location.pathname = e.currentTarget.value;
            }
          });
          window.addEventListener("pageshow", (event) => {
            if (!event.persisted) return;
            const markupSelectedIndex =
              select.querySelector<HTMLOptionElement>("option[selected]")?.index;
            if (markupSelectedIndex !== select.selectedIndex) {
              select.selectedIndex = markupSelectedIndex ?? 0;
            }
          });
        }
      }
      customElements.define("starlight-version-select", StarlightVersionSelect);
    </script>
  )
}

<style>
  @layer starlight.core {
    .doc-version-select {
      --sl-label-icon-size: 0.875rem;
      --sl-caret-size: 1.25rem;
      --sl-inline-padding: 0.5rem;
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.25rem;
      color: var(--sl-color-gray-3);
      cursor: default;
    }

    .doc-version-select--disabled:hover {
      color: var(--sl-color-gray-3);
    }

    .doc-version-select .icon {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
    }

    .doc-version-select select {
      border: 0;
      padding-block: 0.625rem;
      padding-inline: calc(var(--sl-label-icon-size) + var(--sl-inline-padding) + 0.25rem)
        calc(var(--sl-caret-size) + var(--sl-inline-padding) + 0.25rem);
      margin-inline: calc(var(--sl-inline-padding) * -1);
      width: calc(var(--sl-select-width) + var(--sl-inline-padding) * 2);
      background-color: transparent;
      text-overflow: ellipsis;
      color: inherit;
      cursor: not-allowed;
      opacity: 0.85;
      appearance: none;
    }

    .doc-version-select option {
      background-color: var(--sl-color-bg-nav);
      color: var(--sl-color-gray-1);
    }

    @media (min-width: 50rem) {
      .doc-version-select select {
        font-size: var(--sl-text-sm);
      }
    }
  }

  @layer starlight.components {
    .doc-version-select .label-icon {
      font-size: var(--sl-label-icon-size);
      inset-inline-start: 0;
    }

    .doc-version-select .caret {
      font-size: var(--sl-caret-size);
      inset-inline-end: 0;
      opacity: 0.5;
    }
  }
</style>
