---
import { formatBlogDate, isBlogPost } from "../utils/blog-posts";

/** Matches Starlight’s page title anchor (`@astrojs/starlight/constants`). */
const PAGE_TITLE_ID = "_top";

const { entry } = Astro.locals.starlightRoute;
const data = entry.data;
const showMeta = isBlogPost(entry);
const author =
  typeof data.author === "string" && data.author.length > 0
    ? data.author
    : null;
const date = data.date instanceof Date ? data.date : null;
---

<h1 id={PAGE_TITLE_ID}>{data.title}</h1>
{
  showMeta && (author || date) ? (
    <p class="blog-page-meta">
      {author ? <span class="blog-page-meta__author">{author}</span> : null}
      {author && date ? (
        <span class="blog-page-meta__sep" aria-hidden="true">
          ·
        </span>
      ) : null}
      {date ? (
        <time class="blog-page-meta__date" datetime={date.toISOString()}>
          {formatBlogDate(date)}
        </time>
      ) : null}
    </p>
  ) : null
}

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
  }

  .blog-page-meta {
    margin: 0.35rem 0 0;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }

  .blog-page-meta__author {
    font-weight: 500;
    color: var(--sl-color-gray-2);
  }

  .blog-page-meta__sep {
    margin: 0 0.35rem;
  }
</style>
