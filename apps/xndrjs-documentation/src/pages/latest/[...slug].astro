---
import { latestDocPrefix } from "../../../doc-routing.mjs";
import { getLatestDocTailSlugs } from "../../utils/latest-doc-redirects";
import "../../styles/latest-redirect.css";

export async function getStaticPaths() {
  const slugs = await getLatestDocTailSlugs();
  return slugs.map((slug) => ({
    params: { slug },
    props: { target: `/${latestDocPrefix}/${slug}/` },
  }));
}

const { target } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>
      Redirecting to <a href={target}>{target}</a>
    </p>
  </body>
</html>
